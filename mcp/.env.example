# MCP 服务器所需的环境变量
# 复制此文件为 .env，填入真实值，然后在 shell 中 source 它
# source ~/.env  或者加到 ~/.zshrc / ~/.bashrc

# GitHub MCP Server
# 获取地址：https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Apifox MCP Server
# 获取地址：Apifox → 账号设置 → API 访问令牌
APIFOX_ACCESS_TOKEN=afxp_xxxxxxxxxxxxxxxxxxxx
# Apifox 项目 ID（URL 中的数字）
APIFOX_PROJECT_ID=0000000

# Postman MCP Server
# 获取地址：https://go.postman.co/settings/me/api-keys
POSTMAN_API_KEY=PMAK-xxxxxxxxxxxxxxxxxxxx
